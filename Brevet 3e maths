          <label for="countSelect">Nombre de questions</label>
          <select id="countSelect">
            <option value="5">5 questions</option>
            <option value="10">10 questions</option>
            <option value="15">15 questions</option>
            <option value="20">20 questions</option>
          </select>
        </div>
        <button class="btn lavender" id="startQuiz">Démarrer le QCM</button>
      </div>
    </div>
  `;
  $("#startQuiz").addEventListener("click", () => startQuiz(chapter));
}

function startQuiz(chapter) {
  const series = $("#seriesSelect").value;
  const count = Number($("#countSelect").value);
  state.quiz = {
    chapter,
    series,
    questions: makeQuiz(chapter.id, series).slice(0, count),
    index: 0,
    score: 0,
    answered: false,
    selected: null
  };
  drawQuizQuestion();
}

function drawQuizQuestion() {
  const quiz = state.quiz;
  const item = quiz.questions[quiz.index];
  const pct = Math.round(((quiz.index) / quiz.questions.length) * 100);
  $("#chapterModeContainer").innerHTML = `
    <div class="quiz-card">
      <div class="quiz-meta">
        <span class="pill lavender">${quiz.chapter.title}</span>
        <span class="pill blue">Série ${quiz.series}</span>
        <span class="pill mint">Question ${quiz.index + 1}/${quiz.questions.length}</span>
        <span class="pill peach">Score : ${quiz.score}</span>
      </div>
      <div class="progress-bar"><div class="progress-fill" style="width:${pct}%"></div></div>
      <div class="question">${item.question}</div>
      <div class="choices">
        ${item.choices.map((choice, idx) => `<button class="choice" data-choice="${escapeAttr(choice)}">${choice}</button>`).join("")}
      </div>
      <div id="feedbackZone"></div>
      <div class="quiz-actions">
        <div class="left">
          <button class="btn secondary" id="stopQuiz">Arrêter</button>
        </div>
        <button class="btn lavender" id="nextQuestion" disabled>${quiz.index === quiz.questions.length - 1 ? "Voir le résultat" : "Question suivante"}</button>
      </div>
    </div>
  `;
  $$(".choice").forEach(btn => btn.addEventListener("click", () => answerQuestion(btn.dataset.choice)));
  $("#nextQuestion").addEventListener("click", () => nextQuestion());
  $("#stopQuiz").addEventListener("click", () => renderQuizSetup(quiz.chapter));
}

function answerQuestion(choice) {
  const quiz = state.quiz;
  if (quiz.answered) return;
  const item = quiz.questions[quiz.index];
  quiz.answered = true;
  quiz.selected = choice;
  const good = choice === item.correct;
  if (good) quiz.score++;
  $$(".choice").forEach(btn => {
    btn.disabled = true;
    if (btn.dataset.choice === item.correct) btn.classList.add("correct");
    if (btn.dataset.choice === choice && !good) btn.classList.add("wrong");
  });
  $("#feedbackZone").innerHTML = `
    <div class="feedback">
      <strong>${good ? "Bravo, bonne réponse !" : "Pas grave, on corrige."}</strong>
      ${item.encouragement}<br>
      <strong>Correction :</strong> ${item.explanation}<br>
      <strong>Réponse attendue :</strong> ${item.correct}
    </div>
  `;
  $("#nextQuestion").disabled = false;
}

function nextQuestion() {
  const quiz = state.quiz;
  if (quiz.index < quiz.questions.length - 1) {
    quiz.index++;
    quiz.answered = false;
    quiz.selected = null;
    drawQuizQuestion();
  } else {
    drawQuizResult();
  }
}

function drawQuizResult() {
  const quiz = state.quiz;
  const pct = Math.round((quiz.score / quiz.questions.length) * 100);
  const p = chapterProgress(quiz.chapter.id);
  p.bestQuiz = Math.max(p.bestQuiz, pct);
  p.quizzesDone += 1;
  saveProgress();
  const message = pct >= 80 ? "Très solide : ton élève peut passer à des exercices type brevet." : pct >= 50 ? "Bon début : il faut refaire une série puis reprendre les erreurs." : "Il faut reprendre les flashcards et refaire une petite série de 5 questions.";
  $("#chapterModeContainer").innerHTML = `
    <div class="empty-state">
      <span class="pill mint">QCM terminé</span>
      <p class="score-big">${quiz.score}/${quiz.questions.length}</p>
      <h3>${pct}% de réussite</h3>
      <p>${message}</p>
      <div class="quick-actions" style="justify-content:center">
        <button class="btn lavender" id="redoQuiz">Refaire un QCM</button>
        <button class="btn secondary" id="goCards">Revoir les flashcards</button>
      </div>
    </div>
  `;
  $("#redoQuiz").addEventListener("click", () => renderQuizSetup(quiz.chapter));
  $("#goCards").addEventListener("click", () => renderChapter(quiz.chapter.id, "flashcards"));
}

