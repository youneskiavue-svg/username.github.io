    btn.addEventListener("click", () => renderChapter(btn.dataset.chapter, chapterProgress(btn.dataset.chapter).lastMode || "summary"));
  });
  updateProgressDots();
}

function wireMainNav() {
  $$(".nav-item").forEach(btn => {
    btn.addEventListener("click", () => {
