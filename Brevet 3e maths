        const adj = 8 + (i % 5) * 2;
        const opp = Math.tan(angle * Math.PI / 180) * adj;
        qs.push(q(`Côté adjacent ${adj} cm, angle ${angle}°. Côté opposé ≈ ?`, `${comma(opp, 1)} cm`, [`${comma(Math.sin(angle * Math.PI / 180) * adj, 1)} cm`, `${comma(adj / Math.tan(angle * Math.PI / 180), 1)} cm`, `${comma(adj + angle, 1)} cm`], "Avec opposé et adjacent, on utilise la tangente.", "Parfait : tan = opposé / adjacent."));
      } else {
        qs.push(q(`Dans un triangle rectangle, tan(angle) = ?`, "opposé / adjacent", ["adjacent / hypoténuse", "opposé / hypoténuse", "adjacent / opposé"], "La tangente relie le côté opposé et le côté adjacent.", "Bon réflexe : identifie les côtés par rapport à l’angle."));
      }
    }
    return qs;
  },

  transformations(series) {
    const qs = [];
    for (let i = 0; i < 20; i++) {
      const type = i % 4;
      if (type === 0) {
        qs.push(q("Quelle transformation correspond à un glissement sans tourner la figure ?", "Translation", ["Rotation", "Symétrie axiale", "Homothétie"], "Une translation déplace tous les points dans la même direction, le même sens et la même longueur.", "Très bien : translation = glissement."));
      } else if (type === 1) {
        qs.push(q("Quelle transformation correspond à un effet miroir par rapport à une droite ?", "Symétrie axiale", ["Symétrie centrale", "Translation", "Rotation"], "La symétrie axiale se fait par rapport à un axe.", "Bon réflexe : miroir = axe de symétrie."));
      } else if (type === 2) {
        const length = 4 + (i % 5);
        const k = series === "A" ? 2 : 0.5;
        qs.push(q(`Par une homothétie de coefficient ${comma(k)}, une longueur de ${length} cm devient :`, `${comma(length * k, 1)} cm`, [`${comma(length + k, 1)} cm`, `${comma(length / k, 1)} cm`, `${comma(length - k, 1)} cm`], "Une homothétie multiplie toutes les longueurs par son coefficient.", "Excellent : l’homothétie agit sur les longueurs par multiplication."));
      } else {
        qs.push(q("Une rotation est définie par :", "un centre, un angle et un sens", ["une longueur seulement", "deux droites parallèles", "un coefficient seulement"], "Pour tourner une figure, il faut un centre, un angle et un sens de rotation.", "Très bien : tu identifies les données nécessaires."));
      }
    }
    return qs;
  },

  grandeurs(series) {
    const qs = [];
    const shift = series === "A" ? 0 : 2;
    for (let i = 0; i < 20; i++) {
      const type = i % 4;
      if (type === 0) {
        const base = 6 + ((i + shift) % 5);
        const height = 4 + (i % 6);
        qs.push(q(`Aire d’un triangle de base ${base} cm et hauteur ${height} cm ?`, `${base * height / 2} cm²`, [`${base * height} cm²`, `${base + height} cm²`, `${2 * (base + height)} cm²`], "Aire du triangle = base × hauteur ÷ 2.", "Très bien : n’oublie pas de diviser par 2."));
      } else if (type === 1) {
        const l = 4 + (i % 5), w = 3 + ((i + shift) % 4), h = 2 + (i % 3);
        qs.push(q(`Volume d’un pavé droit ${l} cm × ${w} cm × ${h} cm ?`, `${l * w * h} cm³`, [`${l + w + h} cm³`, `${2 * (l*w + l*h + w*h)} cm³`, `${l * w} cm³`], "Volume d’un pavé droit = longueur × largeur × hauteur.", "Parfait : un volume s’exprime en unité cube."));
      } else if (type === 2) {
        const r = 2 + (i % 4), h = 5 + ((i + shift) % 5);
        qs.push(q(`Volume d’un cylindre de rayon ${r} cm et hauteur ${h} cm ?`, `${r*r*h}π cm³`, [`${2*r*h}π cm³`, `${r*h}π cm³`, `${r*r}π cm³`], "Volume du cylindre = aire de la base × hauteur = πr²h.", "Excellent : commence par l’aire du disque de base."));
      } else {
        const dm = 1 + (i % 5);
        qs.push(q(`${dm} dm³ correspond à :`, `${dm} L`, [`${dm * 10} L`, `${dm * 100} L`, `${dm / 10} L`], "1 dm³ = 1 litre.", "Très utile : cette conversion revient souvent."));
      }
    }
    return qs;
  },

  algo(series) {
    const qs = [];
    const shift = series === "A" ? 0 : 2;
    for (let i = 0; i < 20; i++) {
      const type = i % 4;
      if (type === 0) {
        const x = 2 + ((i + shift) % 5);
        const result = (x + 3) * 2;
        qs.push(q(`Programme : choisir ${x}, ajouter 3, multiplier par 2. Résultat ?`, result, [x + 6, x * 2 + 3, x + 3 * 2], "On suit les instructions dans l’ordre : d’abord +3, puis ×2.", "Bien joué : ligne par ligne, on évite les pièges."));
      } else if (type === 1) {
        const start = 1 + (i % 4);
        const loops = 3 + ((i + shift) % 4);
        const add = 2 + (i % 3);
        qs.push(q(`Variable n=${start}. On répète ${loops} fois : ajouter ${add}. Valeur finale ?`, start + loops * add, [start + add, loops * add, start * loops + add], "Une boucle répète la même action plusieurs fois.", "Très bien : multiplie l’ajout par le nombre de répétitions."));
      } else if (type === 2) {
        const n = 4 + i;
        const answer = n % 2 === 0 ? "Vrai" : "Faux";
        qs.push(q(`Condition : “si n est pair”. Pour n=${n}, la condition est :`, answer, [answer === "Vrai" ? "Faux" : "Vrai", "Impossible", "Toujours vraie"], "Un nombre pair est divisible par 2.", "Bon réflexe : une condition se teste avant de choisir la branche."));
      } else {
        qs.push(q("Dans Scratch, une variable sert à :", "stocker une valeur qui peut changer", ["dessiner uniquement un cercle", "arrêter définitivement le programme", "créer une image fixe"], "Une variable est comme une boîte qui contient une valeur.", "Très bien : comprendre les variables aide à suivre le programme."));
      }
    }
    return qs;
  }
};

function isPrimeNumber(n) {
  if (n < 2) return false;
  for (let d = 2; d * d <= n; d++) if (n % d === 0) return false;
  return true;
}

function init() {
