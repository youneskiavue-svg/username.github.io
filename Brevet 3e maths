function pillClass(theme) {
  if (theme.includes("Nombres")) return "blue";
  if (theme.includes("littéral")) return "peach";
  if (theme.includes("données")) return "mint";
  if (theme.includes("géométrie")) return "lavender";
  return "rose";
}

function renderChapter(id, mode = "summary") {
  const chapter = chapters.find(c => c.id === id);
  if (!chapter) return renderHome();
  state.view = "chapter";
  state.currentChapterId = id;
  state.mode = mode;
  state.quiz = null;
  chapterProgress(id).lastMode = mode;
  saveProgress();
  setTitle(chapter.title);
  setActiveNav("", id);

  $("#viewContainer").innerHTML = `
    <section class="card">
      <div class="chapter-header">
        <div>
          <span class="pill ${pillClass(chapter.theme)}">${chapter.icon} ${chapter.theme}</span>
          <h3>${chapter.title}</h3>
          <p>${chapter.summary}</p>
        </div>
        <div class="streak-card">
          <span class="streak-number">${computeChapterPercent(chapter)}%</span>
          <span>maîtrise</span>
        </div>
      </div>
    </section>

    <section class="card">
      <div class="mode-tabs">
        <button class="mode-tab ${mode === "summary" ? "active" : ""}" data-mode="summary">Méthode</button>
        <button class="mode-tab ${mode === "flashcards" ? "active" : ""}" data-mode="flashcards">Flashcards</button>
        <button class="mode-tab ${mode === "quiz" ? "active" : ""}" data-mode="quiz">QCM</button>
      </div>
      <div id="chapterModeContainer"></div>
    </section>
  `;
  $$(".mode-tab").forEach(btn => btn.addEventListener("click", () => renderChapter(id, btn.dataset.mode)));
  if (mode === "summary") renderChapterSummary(chapter);
  if (mode === "flashcards") renderFlashcards(chapter);
  if (mode === "quiz") renderQuizSetup(chapter);
}

function renderChapterSummary(chapter) {
  $("#chapterModeContainer").innerHTML = `
    <div class="grid two">
      <article>
        <h3>Méthode à retenir</h3>
        <ol class="method-list">${chapter.method.map(step => `<li>${step}</li>`).join("")}</ol>
      </article>
      <article>
        <h3>Comment travailler ce chapitre ?</h3>
        <p>1. Lire les flashcards une première fois sans chercher à aller vite.</p>
        <p>2. Faire une série de 5 questions pour tester les bases.</p>
        <p>3. Refaire ensuite une série de 15 ou 20 questions pour gagner en endurance.</p>
        <div class="quick-actions">
          <button class="btn mint" data-jump-mode="flashcards">Lancer les flashcards</button>
          <button class="btn lavender" data-jump-mode="quiz">Lancer un QCM</button>
        </div>
      </article>
    </div>
  `;
  $$('[data-jump-mode]').forEach(btn => btn.addEventListener("click", () => renderChapter(chapter.id, btn.dataset.jumpMode)));
}

function renderFlashcards(chapter) {
  state.flashIndex = Math.min(state.flashIndex, chapter.cards.length - 1);
  state.flashFlipped = false;
  drawFlashcard(chapter);
}

function drawFlashcard(chapter) {
  const [front, back] = chapter.cards[state.flashIndex];
  const known = chapterProgress(chapter.id).cardsKnown;
  const pct = Math.round(((state.flashIndex + 1) / chapter.cards.length) * 100);
  $("#chapterModeContainer").innerHTML = `
    <div class="flashcard-stage">
      <div class="quiz-meta">
        <span class="pill lavender">Carte ${state.flashIndex + 1}/${chapter.cards.length}</span>
        <span class="pill mint">${known}/${chapter.cards.length} cartes maîtrisées</span>
      </div>
      <button class="flashcard" id="flashcardButton" aria-label="Retourner la flashcard">
        <div class="label">${state.flashFlipped ? "Réponse" : "Question"}</div>
        <div class="content">${state.flashFlipped ? back : front}</div>
        <div class="hint">Clique pour retourner la carte</div>
      </button>
      <div class="progress-bar"><div class="progress-fill" style="width:${pct}%"></div></div>
      <div class="flashcard-actions">
        <div class="left">
          <button class="btn secondary" id="prevCard" ${state.flashIndex === 0 ? "disabled" : ""}>← Précédente</button>
          <button class="btn secondary" id="nextCard" ${state.flashIndex === chapter.cards.length - 1 ? "disabled" : ""}>Suivante →</button>
        </div>
        <div class="left">
          <button class="btn peach" id="reviewCard">À revoir</button>
          <button class="btn mint" id="knowCard">Je savais</button>
        </div>
      </div>
    </div>
  `;
  $("#flashcardButton").addEventListener("click", () => {
    state.flashFlipped = !state.flashFlipped;
    drawFlashcard(chapter);
  });
  $("#prevCard").addEventListener("click", () => { state.flashIndex--; state.flashFlipped = false; drawFlashcard(chapter); });
  $("#nextCard").addEventListener("click", () => { state.flashIndex++; state.flashFlipped = false; drawFlashcard(chapter); });
  $("#knowCard").addEventListener("click", () => {
    const p = chapterProgress(chapter.id);
    p.cardsKnown = Math.max(p.cardsKnown, state.flashIndex + 1);
    saveProgress();
    if (state.flashIndex < chapter.cards.length - 1) state.flashIndex++;
    state.flashFlipped = false;
    drawFlashcard(chapter);
  });
  $("#reviewCard").addEventListener("click", () => {
    if (state.flashIndex < chapter.cards.length - 1) state.flashIndex++;
    state.flashFlipped = false;
    drawFlashcard(chapter);
  });
}

function renderQuizSetup(chapter) {
  $("#chapterModeContainer").innerHTML = `
    <div class="quiz-card">
      <div>
        <h3>Configurer le QCM</h3>
        <p>Choisis une série et le nombre de questions. Les deux séries contiennent jusqu’à 20 questions chacune.</p>
      </div>
      <div class="quiz-setup">
        <div class="form-field">
          <label for="seriesSelect">Série</label>
          <select id="seriesSelect">
            <option value="A">Série A · bases et automatismes</option>
            <option value="B">Série B · entraînement renforcé</option>
          </select>
