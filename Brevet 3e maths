const progress = loadProgress();

function loadProgress() {
  try {
    const raw = localStorage.getItem("brevetMathsProgress");
    return raw ? JSON.parse(raw) : {};
  } catch {
    return {};
  }
}

function saveProgress() {
  localStorage.setItem("brevetMathsProgress", JSON.stringify(progress));
  updateGlobalProgress();
  updateProgressDots();
}

function resetProgress() {
  const ok = window.confirm("Réinitialiser toute la progression de révision ?");
  if (!ok) return;
  Object.keys(progress).forEach(key => delete progress[key]);
  localStorage.removeItem("brevetMathsProgress");
  state.currentChapterId = null;
  state.mode = "summary";
  state.flashIndex = 0;
  state.flashFlipped = false;
  state.quiz = null;
  renderHome();
  updateGlobalProgress();
  updateProgressDots();
}

function chapterProgress(id) {
  if (!progress[id]) progress[id] = { bestQuiz: 0, quizzesDone: 0, cardsKnown: 0, lastMode: "summary" };
  return progress[id];
}

function computeChapterPercent(chapter) {
  const p = chapterProgress(chapter.id);
  const cardPct = Math.min(1, p.cardsKnown / chapter.cards.length);
  const quizPct = Math.min(1, p.bestQuiz / 100);
  return Math.round(cardPct * 30 + quizPct * 70);
}

function updateGlobalProgress() {
  const total = chapters.reduce((sum, chapter) => sum + computeChapterPercent(chapter), 0);
  const pct = Math.round(total / chapters.length);
  const node = $("#globalProgress");
  if (node) node.textContent = `${pct}%`;
}

function updateProgressDots() {
  chapters.forEach(chapter => {
    const dot = document.querySelector(`[data-dot-for="${chapter.id}"]`);
    if (!dot) return;
    const pct = computeChapterPercent(chapter);
    dot.classList.toggle("done", pct >= 75);
    dot.classList.toggle("started", pct > 0 && pct < 75);
  });
}

function gcd(a, b) {
  a = Math.abs(a); b = Math.abs(b);
  while (b) [a, b] = [b, a % b];
  return a || 1;
}

function frac(n, d) {
  const sign = n * d < 0 ? "-" : "";
  n = Math.abs(n); d = Math.abs(d);
  const g = gcd(n, d);
  n /= g; d /= g;
  return d === 1 ? `${sign}${n}` : `${sign}${n}/${d}`;
}

function comma(n, digits = 1) {
  const value = Number.isInteger(n) ? n.toString() : n.toFixed(digits).replace(/\.0$/, "");
  return value.replace(".", ",");
}

function unique(values) {
  const out = [];
  values.forEach(v => {
    if (!out.includes(v)) out.push(v);
  });
  return out;
}

function shuffle(arr) {
  const copy = [...arr];
  for (let i = copy.length - 1; i > 0; i--) {
    const j = Math.floor((i + 1) * 0.37) % (i + 1);
    [copy[i], copy[j]] = [copy[j], copy[i]];
  }
  return copy;
}

function q(question, correct, wrongs, explanation, encouragement) {
  const all = unique([String(correct), ...wrongs.map(String)]).slice(0, 4);
  while (all.length < 4) all.push(`Autre réponse ${all.length}`);
  return {
    question,
    correct: String(correct),
    choices: shuffle(all),
    explanation,
    encouragement: encouragement || encouragements[Math.floor(Math.random() * encouragements.length)]
  };
}

function makeQuiz(chapterId, series) {
  const bank = quizFactories[chapterId](series);
  return bank.slice(0, 20);
}

const quizFactories = {
  calculs(series) {
    const qs = [];
    const base = series === "A" ? 0 : 5;
    for (let i = 0; i < 20; i++) {
      const type = i % 4;
      if (type === 0) {
        const a = -8 + base + i;
        const b = 3 + (i % 5);
        const c = -2 - (i % 3);
        const correct = a + b * c;
        qs.push(q(`${a} + ${b} × (${c}) = ?`, correct, [(a + b) * c, a + b + c, a - b * c], "On effectue la multiplication avant l’addition.", "Bon réflexe : pense toujours aux priorités."));
      } else if (type === 1) {
        const d = [4, 5, 6, 8, 10][i % 5];
        const n1 = 1 + (i % 3);
        const n2 = 2 + ((i + base) % 4);
        qs.push(q(`${n1}/${d} + ${n2}/${d} = ?`, frac(n1 + n2, d), [frac(n1 + n2, d * 2), frac(n1 * n2, d), `${n1 + n2}/${d + d}`], "Les dénominateurs sont identiques : on additionne les numérateurs puis on simplifie si possible.", "Très bien, les fractions deviennent plus simples avec l’habitude."));
      } else if (type === 2) {
        const a = -2 - (i % 6);
        const b = series === "A" ? 3 + (i % 5) : -3 - (i % 5);
        const correct = a * b;
        qs.push(q(`(${a}) × (${b}) = ?`, correct, [-correct, a + b, a - b], "Pour une multiplication, deux signes différents donnent un résultat négatif ; deux signes identiques donnent un résultat positif.", "Tu progresses sur les signes, c’est une base essentielle."));
      } else {
        const a = 12 + i;
        const b = 2 + (i % 4);
        const c = 3 + (i % 3);
        const correct = (a - b) / c;
        qs.push(q(`(${a} - ${b}) ÷ ${c} = ?`, comma(correct, 2), [comma(a - b / c, 2), comma(a - b - c, 2), comma(a / c - b, 2)], "On calcule d’abord la parenthèse, puis on divise.", "Bonne méthode : parenthèses d’abord."));
      }
    }
    return qs;
  },

  puissances(series) {
    const qs = [];
    const shift = series === "A" ? 0 : 2;
    for (let i = 0; i < 20; i++) {
      const type = i % 4;
