        const exp = 3 + ((i + shift) % 4);
        qs.push(q(`${comma(coeff)} × 10^${exp} correspond à quel nombre ?`, comma(coeff * 10 ** exp, 0), [comma(coeff * 10 ** (exp - 1), 0), comma(coeff * 10 ** (exp + 1), 0), comma(exp * 10 ** coeff, 0)], "Multiplier par 10ⁿ décale la virgule de n rangs vers la droite.", "Très bon entraînement pour l’écriture scientifique."));
      } else {
